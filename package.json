{
  "name": "battlecaos-voice-channel",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=lcov",
    "start:traced": "node --import ./src/tracing.js src/index.js"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.5.0",
    "kafkajs": "^2.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "nodemon": "^3.1.14",
    "vitest": "^4.1.9"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "include": [
        "src/domain/**"
      ],
      "reporter": [
        "text",
        "html",
        "lcov"
      ]
    }
  }
}
