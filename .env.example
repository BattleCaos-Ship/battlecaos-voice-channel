REDIS_URL=redis://localhost:6379

# Kafka (Upstash o local Docker)
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=battlecaos-voice-channel
# KAFKA_USERNAME=   # solo Upstash — dejar vacío en local
# KAFKA_PASSWORD=   # solo Upstash — dejar vacío en local

# Servidores ICE para WebRTC (JSON array). Si se deja vacío se usa STUN público de Google.
# Para robustez con NAT difíciles, añade un TURN (p.ej. free tier de Metered.ca):
# VOICE_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:tu-turn:3478"],"username":"user","credential":"pass"}]
# VOICE_ICE_SERVERS=
